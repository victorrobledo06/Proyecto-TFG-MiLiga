<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloMain"
        android:layout_width="358dp"
        android:layout_height="52dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_green"
        android:gravity="center"
        android:text="MiLiga"
        android:textColor="@color/backgroundWhite"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnGestionarLigas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/btn_green"
        android:text="Gestionar Ligas"
        android:textColor="@color/backgroundWhite" />

    <Button
        android:id="@+id/btnGestionarEquipos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/btn_green"
        android:text="Gestionar Equipos"
        android:textColor="@color/backgroundWhite" />

    <Button
        android:id="@+id/btnGestionarPartidos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/btn_green"
        android:text="Gestionar Partidos / Clasificación"
        android:textColor="@color/backgroundWhite" />

    <Button
        android:id="@+id/btnGoleadores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/btn_green"
        android:text="Goleadores"
        android:textColor="@color/backgroundWhite" />

    <Button
        android:id="@+id/btnMultimedia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_green"
        android:text="Multimedia"
        android:textColor="@color/backgroundWhite" />

</LinearLayout>
